{
  "name": "@akalforge/supaforge",
  "version": "0.0.3",
  "description": "Diff and sync your Supabase environments",
  "author": "Akal Forge",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/akalforge/supaforge",
    "directory": "packages/cli"
  },
  "type": "module",
  "bin": {
    "supaforge": "./bin/run.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "bin",
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "./bin/dev.js",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "./scripts/test-integration.sh",
    "test:e2e": "vitest run test/e2e/",
    "test:e2e:supabase": "./scripts/test-e2e.sh"
  },
  "oclif": {
    "bin": "supaforge",
    "dirname": "supaforge",
    "commands": {
      "strategy": "pattern",
      "target": "./dist/commands"
    },
    "helpClass": "./dist/help",
    "topicSeparator": " "
  },
  "dependencies": {
    "@dbdiff/cli": "^3.0.0-rc.2",
    "@oclif/core": "^4",
    "@supabase/supabase-js": "^2.103.0",
    "pg": "^8"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/pg": "^8",
    "tsup": "^8.5.1",
    "tsx": "^4",
    "typescript": "^5",
    "vitest": "^3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
