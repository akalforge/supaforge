# ─── Supaforge Environment Variables ─────────────────────────────────────────
# Store database credentials and API keys here. Never commit this file.
# Referenced by supaforge.config.json using $VAR syntax.
#
# Generate this file automatically:  supaforge init
# ──────────────────────────────────────────────────────────────────────────────

# Staging environment
STAGING_DATABASE_URL=postgres://postgres:password@db.STAGING_REF.supabase.co:5432/postgres
STAGING_API_KEY=your-staging-service-role-key

# Production environment
PRODUCTION_DATABASE_URL=postgres://postgres:password@db.PRODUCTION_REF.supabase.co:5432/postgres
PRODUCTION_API_KEY=your-production-service-role-key

# Self-hosted / local example (uncomment if needed):
# LOCAL_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
# LOCAL_API_KEY=eyJhbGci...your-local-service-role-key
